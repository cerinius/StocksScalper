NODE_ENV=development
APP_NAME=stocks-scalper-platform

DATABASE_URL=postgresql://stockradar:stockradar@localhost:55432/stockradar
REDIS_URL=redis://localhost:56379

POSTGRES_PORT=55432
REDIS_PORT=56379
API_PORT=4210
WEB_PORT=3210
GATEWAY_PORT=4211
MT5_ADAPTER_PORT=4310

API_BASE_URL=http://localhost:4210
GATEWAY_BASE_URL=http://localhost:4211
MT5_ADAPTER_URL=http://localhost:4310
NEXT_PUBLIC_API_BASE=http://localhost:4210
NEXT_PUBLIC_GATEWAY_BASE=http://localhost:4211

DISCORD_WEBHOOK_URL=
TRADINGVIEW_WEBHOOK_SECRET=local-tv-secret

WATCHLIST_SYMBOLS=AAPL,MSFT,NVDA,AMD,TSLA,SPY,QQQ,EURUSD,XAUUSD
WATCHLIST_TIMEFRAMES=1m,5m,15m,1h,1d

NEWS_URGENT_INTERVAL_MS=60000
NEWS_BROAD_INTERVAL_MS=300000
MARKET_SCAN_INTERVAL_MS=30000
VALIDATION_INTERVAL_MS=120000
EXECUTION_INTERVAL_MS=10000
SUPERVISOR_INTERVAL_MS=20000
DAILY_SUMMARY_CRON=55 23 * * *
MT5_SYNC_INTERVAL_MS=30000

TRADING_MODE=paper
MANUAL_APPROVAL_MODE=false
KILL_SWITCH=false

MAX_ACTIVE_TRADES=4
MAX_DAILY_LOSS_PCT=3
MAX_RISK_PER_TRADE_PCT=0.75
MAX_TOTAL_EXPOSURE_PCT=20
MAX_SYMBOL_EXPOSURE_PCT=8
MAX_CORRELATED_EXPOSURE_PCT=12
COOLDOWN_AFTER_LOSSES=2
COOLDOWN_MINUTES=45
STALE_SIGNAL_SECONDS=300

LOCAL_ADMIN_EMAIL=admin@stockradar.local
LOCAL_ADMIN_NAME=Local Admin
